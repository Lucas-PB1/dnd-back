{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/fighting-styles.schema.json",
  "title": "Estilos de luta por classe",
  "type": "object",
  "required": ["id", "source", "unlockLevel", "classesWithFightingStyle", "standardStyleIds"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "unlockLevel": { "type": "integer", "minimum": 1 },
    "classesWithFightingStyle": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "standardStyleIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "acBonuses": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
      "additionalProperties": {
        "type": "object",
        "required": ["bonus"],
        "properties": {
          "bonus": { "type": "integer" },
          "requiresEquippedArmor": { "type": "boolean" },
          "armorCategories": {
            "type": "array",
            "items": { "type": "string", "enum": ["light", "medium", "heavy", "shield"] }
          }
        },
        "additionalProperties": false
      }
    }
  }
}
