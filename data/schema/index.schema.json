{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/index.schema.json",
  "title": "Índice PHB — Classes",
  "type": "object",
  "required": ["source", "classCount", "subclassCount", "classes"],
  "properties": {
    "$schema": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "classCount": { "type": "integer", "minimum": 1 },
    "subclassCount": { "type": "integer", "minimum": 1 },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "file", "subclasses"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "file": { "type": "string" },
          "subclasses": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "file"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "file": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
