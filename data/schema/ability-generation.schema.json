{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/ability-generation.schema.json",
  "title": "Geração de atributos PHB",
  "type": "object",
  "required": ["id", "source", "methods", "pointBuyCosts", "backgroundBoost"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "methods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "values": { "type": "array", "items": { "type": "integer" }, "minItems": 6, "maxItems": 6 },
          "totalPoints": { "type": "integer" }
        }
      },
      "minItems": 3,
      "maxItems": 3
    },
    "pointBuyCosts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["score", "cost"],
        "properties": {
          "score": { "type": "integer" },
          "cost": { "type": "integer" }
        }
      }
    },
    "standardArrayByClass": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["classId", "forca", "destreza", "constituicao", "inteligencia", "sabedoria", "carisma"],
        "properties": {
          "classId": { "type": "string" },
          "forca": { "type": "integer" },
          "destreza": { "type": "integer" },
          "constituicao": { "type": "integer" },
          "inteligencia": { "type": "integer" },
          "sabedoria": { "type": "integer" },
          "carisma": { "type": "integer" }
        }
      },
      "minItems": 12,
      "maxItems": 12
    },
    "backgroundBoost": { "type": "object" },
    "backgroundPrimaryAbilityHints": { "type": "array" }
  }
}
