{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/gear.schema.json",
  "title": "Equipamento de Aventura PHB",
  "type": "object",
  "required": ["id", "source", "items"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "description": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "weight", "cost"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "weight": { "type": "string" },
          "cost": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
