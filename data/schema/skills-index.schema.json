{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/skills-index.schema.json",
  "title": "Índice de perícias e atributos PHB",
  "type": "object",
  "required": ["source", "abilities", "skills"],
  "properties": {
    "$schema": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "abilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "name": { "type": "string" }
        }
      },
      "minItems": 6,
      "maxItems": 6
    },
    "skillCount": { "type": "integer", "const": 18 },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "ability", "file"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "name": { "type": "string" },
          "ability": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "file": { "type": "string" }
        }
      },
      "minItems": 18,
      "maxItems": 18
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file", "title"],
        "properties": {
          "id": { "type": "string" },
          "file": { "type": "string" },
          "title": { "type": "string" },
          "pdfPages": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 1,
            "maxItems": 2
          }
        }
      }
    }
  }
}
