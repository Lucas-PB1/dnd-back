{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/spells-by-class-index.schema.json",
  "title": "Índice de Listas de Magia por Classe",
  "type": "object",
  "required": ["source", "classCount", "classes"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "classCount": { "type": "integer", "const": 8 },
    "classes": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["classId", "className", "file", "spellCount"],
        "properties": {
          "classId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "className": { "type": "string" },
          "file": { "type": "string" },
          "spellCount": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
