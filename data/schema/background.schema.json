{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/background.schema.json",
  "title": "Antecedente PHB",
  "description": "Antecedente do Livro do Jogador 2024 (PT-BR).",
  "type": "object",
  "required": [
    "id",
    "name",
    "source",
    "description",
    "abilityOptions",
    "feat",
    "skillIds",
    "toolProficiency",
    "equipment"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "description": { "type": "string", "minLength": 20 },
    "abilityOptions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3,
      "maxItems": 3
    },
    "feat": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "spellList": {
          "type": "string",
          "enum": ["Clérigo", "Druida", "Mago"]
        }
      }
    },
    "skillIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "minItems": 2,
      "maxItems": 2
    },
    "toolProficiency": {
      "type": "object",
      "required": ["description", "kind"],
      "properties": {
        "description": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["fixed", "choice"]
        },
        "category": { "type": "string" },
        "itemId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "fixed" } } },
          "then": { "required": ["itemId"] }
        }
      ]
    },
    "equipment": {
      "type": "object",
      "required": ["goldOption", "packages"],
      "properties": {
        "goldOption": { "type": "integer", "minimum": 0 },
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "label", "items"],
            "properties": {
              "id": { "type": "string", "enum": ["a"] },
              "label": { "type": "string" },
              "items": {
                "type": "array",
                "items": { "$ref": "equipment-entry.schema.json" },
                "minItems": 1
              },
              "gold": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
