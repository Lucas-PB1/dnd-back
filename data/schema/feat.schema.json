{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/feat.schema.json",
  "title": "Talento PHB",
  "description": "Talento do Livro do Jogador 2024 (PT-BR).",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "categoryLabel",
    "typeLabel",
    "repeatable",
    "source",
    "benefits"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Identificador estável em inglês (slug)."
    },
    "name": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["origin", "general", "fighting-style", "epic-boon"]
    },
    "categoryLabel": { "type": "string" },
    "typeLabel": { "type": "string" },
    "repeatable": { "type": "boolean" },
    "prerequisite": {
      "type": ["string", "null"],
      "description": "Pré-requisitos em texto livre (PT-BR)."
    },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "benefits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
