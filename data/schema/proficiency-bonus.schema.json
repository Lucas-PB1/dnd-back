{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/proficiency-bonus.schema.json",
  "title": "Bônus de proficiência PHB",
  "type": "object",
  "required": ["id", "source", "byLevelOrCR"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "description": { "type": "string" },
    "byLevelOrCR": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["levelMin", "levelMax", "bonus"],
        "properties": {
          "levelMin": { "type": "integer", "minimum": 1 },
          "levelMax": { "type": "integer", "minimum": 1 },
          "bonus": { "type": "integer", "minimum": 2 }
        }
      },
      "minItems": 1
    },
    "byChallengeRating": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["crMin", "crMax", "bonus"],
        "properties": {
          "crMin": { "type": "integer", "minimum": 0 },
          "crMax": { "type": "integer", "minimum": 0 },
          "bonus": { "type": "integer", "minimum": 2 }
        }
      }
    },
    "doesNotStack": { "type": "boolean" }
  }
}
