{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/character.schema.json",
  "title": "Ficha de personagem",
  "description": "Instância de personagem — referencia regras em data/phb/ por id, com escolhas do jogador e estado de jogo.",
  "type": "object",
  "required": [
    "id",
    "name",
    "level",
    "speciesId",
    "backgroundId",
    "classId",
    "alignmentId",
    "abilityGeneration",
    "languageIds",
    "abilities",
    "skillProficiencies",
    "savingThrowProficiencies",
    "feats",
    "startingPackages",
    "equipment",
    "hp",
    "resources"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "level": { "type": "integer", "minimum": 1, "maximum": 20 },
    "speciesId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "speciesChoices": { "$ref": "#/$defs/speciesChoices" },
    "backgroundId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "classId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "subclassId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "classChoices": { "$ref": "#/$defs/classChoices" },
    "alignmentId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "abilityGeneration": { "$ref": "#/$defs/abilityGeneration" },
    "languageIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "minItems": 1,
      "uniqueItems": true
    },
    "abilities": { "$ref": "#/$defs/abilities" },
    "skillProficiencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillProficiency" },
      "uniqueItems": true
    },
    "expertise": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "savingThrowProficiencies": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["forca", "destreza", "constituicao", "inteligencia", "sabedoria", "carisma"]
      },
      "uniqueItems": true,
      "minItems": 2,
      "maxItems": 2
    },
    "feats": {
      "type": "array",
      "items": { "$ref": "#/$defs/featRef" },
      "minItems": 1
    },
    "spellcasting": { "$ref": "#/$defs/spellcasting" },
    "startingPackages": { "$ref": "#/$defs/startingPackages" },
    "equipment": {
      "type": "array",
      "items": { "$ref": "#/$defs/equipmentItem" }
    },
    "hp": { "$ref": "#/$defs/hp" },
    "resources": { "$ref": "#/$defs/resources" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false,
  "$defs": {
    "abilities": {
      "type": "object",
      "required": ["forca", "destreza", "constituicao", "inteligencia", "sabedoria", "carisma"],
      "properties": {
        "forca": { "type": "integer", "minimum": 1, "maximum": 30 },
        "destreza": { "type": "integer", "minimum": 1, "maximum": 30 },
        "constituicao": { "type": "integer", "minimum": 1, "maximum": 30 },
        "inteligencia": { "type": "integer", "minimum": 1, "maximum": 30 },
        "sabedoria": { "type": "integer", "minimum": 1, "maximum": 30 },
        "carisma": { "type": "integer", "minimum": 1, "maximum": 30 }
      },
      "additionalProperties": false
    },
    "speciesChoices": {
      "type": "object",
      "description": "Escolhas dentro da espécie (linhagem, perícia de Sentidos Aguçados, etc.).",
      "properties": {
        "lineageId": {
          "type": "string",
          "enum": ["high-elf", "drow", "wood-elf"]
        },
        "keenSensesSkillId": {
          "type": "string",
          "enum": ["insight", "perception", "survival"]
        }
      },
      "additionalProperties": false
    },
    "classChoices": {
      "type": "object",
      "properties": {
        "divineOrder": {
          "type": "string",
          "enum": ["protector", "thaumaturge"]
        },
        "skillIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        }
      },
      "additionalProperties": false
    },
    "abilityGeneration": {
      "type": "object",
      "required": ["methodId"],
      "properties": {
        "methodId": {
          "type": "string",
          "enum": ["standard-array", "roll", "point-buy"]
        },
        "backgroundBoostId": {
          "type": "string",
          "enum": ["two-and-one", "three-plus-one"]
        }
      },
      "additionalProperties": false
    },
    "skillProficiency": {
      "type": "object",
      "required": ["skillId", "source"],
      "properties": {
        "skillId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source": {
          "type": "string",
          "enum": ["background", "class", "species", "feat", "other"]
        }
      },
      "additionalProperties": false
    },
    "featRef": {
      "type": "object",
      "required": ["featId", "source"],
      "properties": {
        "featId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source": {
          "type": "string",
          "enum": ["background", "class", "species", "general", "other"]
        },
        "magicInitiate": {
          "type": "object",
          "required": ["spellListClassId", "cantripIds", "preparedSpellId"],
          "properties": {
            "spellListClassId": {
              "type": "string",
              "enum": ["cleric", "druid", "wizard"]
            },
            "cantripIds": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
              "minItems": 2,
              "maxItems": 2
            },
            "preparedSpellId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
            "castingAbilityId": {
              "type": "string",
              "enum": ["inteligencia", "sabedoria", "carisma"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "spellsBySource": {
      "type": "object",
      "description": "Mapa origem → lista de spellId. Origens comuns: class, magic-initiate, elf-lineage, life-domain.",
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "uniqueItems": true
      }
    },
    "spellcasting": {
      "type": "object",
      "required": ["cantrips", "prepared", "slotsMax"],
      "properties": {
        "cantrips": { "$ref": "#/$defs/spellsBySource" },
        "prepared": { "$ref": "#/$defs/spellsBySource" },
        "slotsMax": {
          "type": "object",
          "propertyNames": { "pattern": "^[1-9]$" },
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "slotsUsed": {
          "type": "object",
          "propertyNames": { "pattern": "^[1-9]$" },
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "additionalProperties": false
    },
    "startingPackages": {
      "type": "object",
      "required": ["classOption", "backgroundOption"],
      "properties": {
        "classOption": { "type": "string" },
        "backgroundOption": { "type": "string" }
      },
      "additionalProperties": false
    },
    "equipmentItem": {
      "type": "object",
      "required": ["itemId", "source"],
      "properties": {
        "itemId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "quantity": { "type": "integer", "minimum": 1, "default": 1 },
        "source": {
          "type": "string",
          "enum": ["class-starting", "background-starting", "purchased", "other"]
        },
        "equipped": { "type": "boolean" },
        "slot": {
          "type": "string",
          "enum": ["armor", "shield", "mainHand", "offHand", "focus", "other"]
        }
      },
      "additionalProperties": false
    },
    "hp": {
      "type": "object",
      "required": ["current", "max"],
      "properties": {
        "current": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 1 },
        "temp": { "type": "integer", "minimum": 0, "default": 0 }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "properties": {
        "channelDivinity": {
          "type": "object",
          "required": ["max", "remaining"],
          "properties": {
            "max": { "type": "integer", "minimum": 0 },
            "remaining": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  }
}
