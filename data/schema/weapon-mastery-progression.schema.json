{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/weapon-mastery-progression.schema.json",
  "title": "Progressão de maestria em armas por classe",
  "type": "object",
  "required": ["id", "source", "classes"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "featBonus": {
      "type": "object",
      "required": ["featId", "extraSlots"],
      "properties": {
        "featId": { "type": "string" },
        "extraSlots": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "classes": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
      "additionalProperties": { "$ref": "#/$defs/classMastery" }
    }
  },
  "$defs": {
    "classMastery": {
      "type": "object",
      "required": ["allowedCategories", "allowedTypes", "slotsByLevel"],
      "properties": {
        "allowedCategories": {
          "type": "array",
          "items": { "type": "string", "enum": ["simple", "martial"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "allowedTypes": {
          "type": "array",
          "items": { "type": "string", "enum": ["melee", "ranged"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "slotsByLevel": {
          "type": "object",
          "propertyNames": { "pattern": "^[0-9]+$" },
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "additionalProperties": false
    }
  }
}
