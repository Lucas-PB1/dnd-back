{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/ability-modifiers.schema.json",
  "title": "Modificadores de atributo PHB",
  "type": "object",
  "required": ["id", "source", "abilities", "modifierTable"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "abilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "measures"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "measures": { "type": "string" }
        }
      },
      "minItems": 6,
      "maxItems": 6
    },
    "modifierTable": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scoreMin", "scoreMax", "modifier"],
        "properties": {
          "scoreMin": { "type": "integer", "minimum": 1 },
          "scoreMax": { "type": "integer", "minimum": 1 },
          "modifier": { "type": "integer" }
        }
      },
      "minItems": 1
    }
  }
}
