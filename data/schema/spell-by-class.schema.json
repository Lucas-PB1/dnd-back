{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/spell-by-class.schema.json",
  "title": "Lista de Magias por Classe",
  "description": "Índice invertido de magias elegíveis para uma classe conjuradora do PHB 2024 (PT-BR).",
  "type": "object",
  "required": [
    "classId",
    "className",
    "listLabel",
    "source",
    "spellCount",
    "byLevel"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "classId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "className": { "type": "string", "minLength": 1 },
    "listLabel": { "type": "string", "minLength": 1 },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "spellCount": { "type": "integer", "minimum": 1 },
    "byLevel": {
      "type": "object",
      "propertyNames": { "pattern": "^[0-9]$" },
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "school"],
          "properties": {
            "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            "name": { "type": "string" },
            "school": { "type": "string" },
            "ritual": { "type": "boolean" },
            "concentration": { "type": "boolean" }
          }
        }
      }
    }
  }
}
