{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/backgrounds-index.schema.json",
  "title": "Índice PHB — Antecedentes",
  "type": "object",
  "required": ["source", "backgroundCount", "backgrounds"],
  "properties": {
    "$schema": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "backgroundCount": { "type": "integer", "minimum": 1 },
    "backgrounds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "file", "featId"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "file": { "type": "string" },
          "featId": { "type": "string" },
          "featSpellList": { "type": "string" }
        }
      }
    }
  }
}
