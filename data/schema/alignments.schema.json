{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/alignments.schema.json",
  "title": "Alinhamentos PHB",
  "type": "object",
  "required": ["id", "source", "alignments"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "summary": { "type": "string" },
    "axes": { "type": "object" },
    "alignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "abbreviation", "name", "morality", "order", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "abbreviation": { "type": "string" },
          "name": { "type": "string" },
          "morality": { "type": "string" },
          "order": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "minItems": 9,
      "maxItems": 9
    },
    "noAlignmentNote": { "type": "string" }
  }
}
