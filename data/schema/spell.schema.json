{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/spell.schema.json",
  "title": "Magia PHB",
  "description": "Magia do Livro do Jogador 2024 (PT-BR).",
  "type": "object",
  "required": [
    "id",
    "name",
    "level",
    "levelLabel",
    "school",
    "classes",
    "castingTime",
    "range",
    "components",
    "duration",
    "concentration",
    "ritual",
    "description",
    "source"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Slug estável derivado do nome em PT-BR."
    },
    "name": { "type": "string" },
    "level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9,
      "description": "0 = truque."
    },
    "levelLabel": { "type": "string" },
    "school": { "type": "string" },
    "classes": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "castingTime": { "type": "string" },
    "range": { "type": "string" },
    "components": {
      "type": "object",
      "required": ["verbal", "somatic", "material", "text"],
      "properties": {
        "verbal": { "type": "boolean" },
        "somatic": { "type": "boolean" },
        "material": { "type": "boolean" },
        "materialDescription": { "type": ["string", "null"] },
        "text": { "type": "string" }
      }
    },
    "duration": { "type": "string" },
    "concentration": { "type": "boolean" },
    "ritual": { "type": "boolean" },
    "description": { "type": "string" },
    "higherLevels": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" }
  }
}
