{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/armor.schema.json",
  "title": "Armaduras PHB",
  "type": "object",
  "required": ["id", "source", "items"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/armorItem" }
    }
  },
  "$defs": {
    "acFormula": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["dex-plus-base", "fixed", "shield-bonus"]
        },
        "base": { "type": "integer", "minimum": 0 },
        "dexMax": { "type": "integer", "minimum": 0 },
        "bonus": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "dex-plus-base" } }, "required": ["type"] },
          "then": { "required": ["base"] }
        },
        {
          "if": { "properties": { "type": { "const": "fixed" } }, "required": ["type"] },
          "then": { "required": ["base"] }
        },
        {
          "if": { "properties": { "type": { "const": "shield-bonus" } }, "required": ["type"] },
          "then": { "required": ["bonus"] }
        }
      ]
    },
    "armorItem": {
      "type": "object",
      "required": ["id", "name", "category", "ac", "weight", "cost", "acFormula", "propertyIds"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["light", "medium", "heavy", "shield"] },
        "ac": { "type": "string", "description": "Texto legado da tabela PHB." },
        "acFormula": { "$ref": "#/$defs/acFormula" },
        "propertyIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "uniqueItems": true
        },
        "strengthMinimum": { "type": "integer", "minimum": 1 },
        "strength": { "type": ["string", "null"] },
        "stealthDisadvantage": { "type": "boolean" },
        "weight": { "type": "string" },
        "cost": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
