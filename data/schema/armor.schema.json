{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/armor.schema.json",
  "title": "Armaduras PHB",
  "type": "object",
  "required": ["id", "source", "items"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "ac", "weight", "cost"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "ac": { "type": "string" },
          "strength": { "type": ["string", "null"] },
          "stealthDisadvantage": { "type": "boolean" },
          "weight": { "type": "string" },
          "cost": { "type": "string" }
        }
      }
    }
  }
}
