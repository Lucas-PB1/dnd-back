{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/hp-rules.schema.json",
  "title": "Regras de pontos de vida PHB",
  "type": "object",
  "required": ["id", "source", "level1MaxHp", "fixedHpPerLevel"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "level1MaxHp": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["classIds", "hitDie", "formula"],
        "properties": {
          "classIds": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            "minItems": 1
          },
          "hitDie": { "type": "string", "pattern": "^D\\d+$" },
          "formula": { "type": "string" }
        }
      },
      "minItems": 4,
      "maxItems": 4
    },
    "fixedHpPerLevel": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["classIds", "formula", "minimumGain"],
        "properties": {
          "classIds": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            "minItems": 1
          },
          "formula": { "type": "string" },
          "minimumGain": { "type": "integer", "minimum": 1 }
        }
      },
      "minItems": 4,
      "maxItems": 4
    },
    "levelUpSteps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hitDiceAtLevel1": { "type": "integer", "minimum": 1 },
    "multiclassNote": { "type": "string" }
  }
}
