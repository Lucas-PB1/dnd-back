{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/weapon.schema.json",
  "title": "Armas PHB",
  "type": "object",
  "required": ["id", "source", "weapons"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "groups": { "type": "array" },
    "weapons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "group", "category", "type", "damage", "damageType", "weight", "cost"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "group": { "type": "string" },
          "category": { "type": "string", "enum": ["simple", "martial"] },
          "type": { "type": "string", "enum": ["melee", "ranged"] },
          "damage": { "type": "string" },
          "damageType": { "type": "string" },
          "properties": { "type": ["string", "null"] },
          "mastery": { "type": ["string", "null"] },
          "weight": { "type": "string" },
          "cost": { "type": "string" }
        }
      }
    }
  }
}
