{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/tool.schema.json",
  "title": "Ferramentas PHB",
  "type": "object",
  "required": ["id", "source", "tools"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "description": { "type": "string" },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "cost"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "cost": { "type": "string" },
          "attribute": { "type": ["string", "null"] },
          "weight": { "type": ["string", "null"] },
          "useObject": { "type": ["string", "null"] },
          "crafting": { "type": ["string", "null"] },
          "variants": { "type": ["string", "null"] }
        }
      }
    }
  }
}
