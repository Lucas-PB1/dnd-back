{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/saving-throws.schema.json",
  "title": "Salvaguardas PHB",
  "type": "object",
  "required": ["id", "source", "byAbility"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "summary": { "type": "string" },
    "proficiencyRule": { "type": "string" },
    "byAbility": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["abilityId", "example"],
        "properties": {
          "abilityId": { "type": "string" },
          "example": { "type": "string" }
        }
      },
      "minItems": 6,
      "maxItems": 6
    }
  }
}
