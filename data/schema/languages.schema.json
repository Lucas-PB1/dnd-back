{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/languages.schema.json",
  "title": "Idiomas PHB",
  "type": "object",
  "required": ["id", "source", "startingRule", "commonTable", "languages"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "startingRule": { "type": "object" },
    "commonTable": { "type": "array", "minItems": 1 },
    "rareLanguages": { "type": "array" },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "name": { "type": "string" },
          "category": { "enum": ["common", "rare"] }
        }
      },
      "minItems": 10
    }
  }
}
