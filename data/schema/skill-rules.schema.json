{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/skill-rules.schema.json",
  "title": "Regras de perícias PHB",
  "type": "object",
  "required": ["id", "title", "source"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "actionId": { "type": "string" },
    "skillId": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "summary": { "type": "string" },
    "intro": { "type": "string" },
    "formula": { "type": "string" },
    "advantageModifier": { "type": "integer" },
    "disadvantageModifier": { "type": "integer" },
    "workedExample": { "type": "string" },
    "alternateAbilityExample": {
      "type": "object",
      "required": ["skillId", "defaultAbilityId", "alternateAbilityId", "situation"],
      "properties": {
        "skillId": { "type": "string" },
        "defaultAbilityId": { "type": "string" },
        "alternateAbilityId": { "type": "string" },
        "situation": { "type": "string" }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        ]
      }
    },
    "bySkill": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skillId"],
        "properties": {
          "skillId": { "type": "string" },
          "topics": { "type": "array", "items": { "type": "string" } },
          "creatureTypes": { "type": "array", "items": { "type": "string" } },
          "detects": { "type": "string" },
          "abilityId": { "type": "string" },
          "interaction": { "type": "string" }
        }
      }
    }
  }
}
