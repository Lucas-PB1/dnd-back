{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/species-index.schema.json",
  "title": "Índice de espécies PHB",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "speciesCount", "species"],
  "properties": {
    "$schema": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "speciesCount": { "type": "integer", "const": 10 },
    "species": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "pattern": "^[a-z][a-z0-9-]+\\.json$" }
        }
      }
    }
  }
}
