{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/ability-checks.schema.json",
  "title": "Testes de atributo PHB",
  "type": "object",
  "required": ["id", "source", "defaultDifficulty", "byAbility"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "summary": { "type": "string" },
    "proficiencyRule": { "type": "string" },
    "defaultDifficulty": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "dc"],
        "properties": {
          "label": { "type": "string" },
          "dc": { "type": "integer", "minimum": 1 }
        }
      },
      "minItems": 6,
      "maxItems": 6
    },
    "byAbility": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["abilityId", "example"],
        "properties": {
          "abilityId": { "type": "string" },
          "example": { "type": "string" }
        }
      },
      "minItems": 6,
      "maxItems": 6
    },
    "skillRule": { "type": "string" },
    "alternateAbilityRule": { "type": "string" }
  }
}
