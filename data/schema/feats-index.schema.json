{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/feats-index.schema.json",
  "title": "Índice de Talentos PHB",
  "type": "object",
  "required": ["source", "featCount", "byCategory", "feats"],
  "properties": {
    "$schema": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "featCount": { "type": "integer", "minimum": 1 },
    "byCategory": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "feats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "repeatable", "file"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "repeatable": { "type": "boolean" },
          "file": { "type": "string" }
        }
      }
    }
  }
}
