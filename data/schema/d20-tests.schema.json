{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/d20-tests.schema.json",
  "title": "Testes de D20 PHB",
  "type": "object",
  "required": ["id", "source", "steps", "types"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["order", "title", "text"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "text": { "type": "string" }
        }
      },
      "minItems": 3,
      "maxItems": 3
    },
    "types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "targetLabel"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "targetLabel": { "type": "string" }
        }
      },
      "minItems": 3,
      "maxItems": 3
    }
  }
}
