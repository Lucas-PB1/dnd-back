{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/subclass.schema.json",
  "title": "Subclasse PHB",
  "description": "Subclasse de personagem do Livro do Jogador 2024 (PT-BR). classId referencia o id da classe em classes/.",
  "type": "object",
  "required": ["id", "classId", "name", "source", "tagline", "summary", "features"],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Identificador estável em inglês (slug)."
    },
    "classId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Referência textual à classe (ex.: barbarian)."
    },
    "name": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "tagline": { "type": "string" },
    "summary": { "type": "string" },
    "description": { "type": "string" },
    "features": {
      "type": "array",
      "items": { "$ref": "class.schema.json#/$defs/feature" }
    }
  }
}
