{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schema/equipment-rules.schema.json",
  "title": "Regras de Equipamento PHB",
  "type": "object",
  "required": ["id", "source"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "source": { "$ref": "class.schema.json#/$defs/source" },
    "intro": { "type": "string" },
    "description": { "type": "string" },
    "selling": { "type": "string" },
    "training": { "type": "string" },
    "variant": { "type": "string" },
    "proficiency": { "type": "string" },
    "improvised": { "type": "string" },
    "properties": { "type": "array" },
    "masteryProperties": { "type": "array" },
    "scrollCosts": { "type": "array" },
    "coins": { "type": "array" },
    "categories": { "type": "array" },
    "lifestyle": { "type": "object" },
    "sectionText": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
