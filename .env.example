# Banco local (dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Migrations/seeds — session pooler (5432) ou direct db.[ref].supabase.co
# No Windows, direct costuma ser IPv6-only; prefira pooler com usuário postgres.[ref] e senha URL-encoded
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-N-[region].pooler.supabase.com:5432/postgres
SUPABASE_DATABASE_URL=

# Supabase
SUPABASE_URL=https://your-project.supabase.co

# App
FRONTEND_URL=http://localhost:3001
PORT=3000
NODE_ENV=development

# --- Vercel (Production / Preview) ---
# DATABASE_URL = transaction pooler (6543), NÃO a URL direct 5432:
# postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# SUPABASE_URL = https://[ref].supabase.co
# FRONTEND_URL = https://seu-front.vercel.app
# NODE_ENV = production
