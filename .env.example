# Banco local (dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Supabase direct — só migrations/seeds (porta 5432)
SUPABASE_DATABASE_URL=

# Supabase
SUPABASE_URL=https://your-project.supabase.co

# App
FRONTEND_URL=http://localhost:3001
PORT=3000
NODE_ENV=development

# --- Vercel (Production / Preview) ---
# DATABASE_URL = transaction pooler (6543), NÃO a URL direct 5432:
# postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# SUPABASE_URL = https://[ref].supabase.co
# FRONTEND_URL = https://seu-front.vercel.app
# NODE_ENV = production
