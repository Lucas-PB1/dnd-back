{
  "name": "dnd-api",
  "version": "1.0.0",
  "private": true,
  "description": "PostgreSQL — catálogo PHB 2024 + API NestJS",
  "license": "ISC",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "vercel:dev": "vercel dev --listen 3000",
    "vercel:smoke": "node scripts/vercel-local-smoke.mjs",
    "smoke:health": "node scripts/smoke-health.mjs",
    "smoke:prod": "node scripts/smoke-health.mjs",
    "db:reset": "node scripts/dev-reset.mjs",
    "db:migrate": "node scripts/run-migrations.mjs",
    "db:migrate:supabase": "node scripts/run-migrations.mjs --target=supabase",
    "db:migrate:all": "node scripts/run-migrations.mjs --target=all",
    "db:migrate:baseline": "node scripts/baseline-migrations.mjs",
    "db:migrate:baseline:all": "node scripts/baseline-migrations.mjs --target=all",
    "db:seed": "node scripts/run-seeds.mjs",
    "db:seed:supabase": "node scripts/run-seeds.mjs --target=supabase",
    "db:seed:all": "node scripts/run-seeds.mjs --target=all",
    "db:setup": "npm run db:reset && npm run db:migrate && npm run db:seed",
    "db:setup:all": "npm run db:setup && npm run db:migrate:supabase && npm run db:seed:supabase",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.config.js --runInBand"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.12",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.22"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/testing": "^11.1.27",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.8.3",
    "vercel": "^54.20.1"
  }
}
